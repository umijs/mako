{
  "rootPath": "../../",
  "projectPath": "./",
  "config": {
    "entry": [
      {
        "import": "./src/index.tsx"
      }
    ],
    "output": {
      "path": "./dist",
      "filename": "[name].[contenthash:6].js",
      "chunkFilename": "[name].[contenthash:8].js"
    },
    "optimization": {
      "moduleIds": "named",
      "minify": false,
      "splitChunks": {
        "js": {
          "minChunkSize": 100,
          "maxChunkCountPerGroup": 10,
          "maxMergeChunkSize": 1000
        },
        "css": {
          "minChunkSize": 100,
          "maxChunkCountPerGroup": 20,
          "maxMergeChunkSize": 1000
        }
      }
    }
  }
}
